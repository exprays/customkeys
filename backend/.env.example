# Server
PORT=8080
APP_ENV=development
APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-id.supabase.co
SUPABASE_JWT_SECRET=your-secret
# Database (Supabase Postgres)
DATABASE_URL=postgresql://your-url

# Redis (Upstash)
REDIS_URL=redis://your-url

# Encryption
ENCRYPTION_KEY=32-byte-hex-key-here
AUDIT_HMAC_KEY=another-32-byte-hex-key

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.nano.dev

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@nano.dev
EMAIL_FROM_NAME=Nano

# Razorpay billing
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RZP_PLAN_STARTER=plan_starter_monthly_id
RZP_PLAN_BUSINESS=plan_business_monthly_id