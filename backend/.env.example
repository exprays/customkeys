# Server
PORT=8080
APP_ENV=development
APP_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Supabase Postgres)
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379

# Encryption
ENCRYPTION_KEY=32-byte-hex-key-here
AUDIT_HMAC_KEY=another-32-byte-hex-key

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.nano.dev

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@nano.dev
EMAIL_FROM_NAME=Nano

# LemonSqueezy billing
LEMONSQUEEZY_API_KEY=eyJ...
LEMONSQUEEZY_SIGNING_SECRET=your-webhook-signing-secret
LEMONSQUEEZY_STORE_ID=12345
LS_VARIANT_TEAM=111111
LS_VARIANT_BUSINESS=222222
LS_VARIANT_ENTERPRISE=333333